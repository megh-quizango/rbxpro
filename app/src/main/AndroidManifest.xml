<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RBXApp">

        <activity
            android:name=".SplashActivity"
            android:theme="@style/Theme.RBXApp.Splash"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <activity
            android:name=".CalculatorActivity"
            android:exported="false"
            android:theme="@style/Theme.RBXApp" />

        <activity
            android:name=".QuizActivity"
            android:exported="false"
            android:theme="@style/Theme.RBXApp" />

        <activity
            android:name=".TipsTricksActivity"
            android:exported="false"
            android:theme="@style/Theme.RBXApp" />

        <activity
            android:name=".TipDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.RBXApp" />

        <activity
            android:name=".MemeActivity"
            android:exported="false"
            android:theme="@style/Theme.RBXApp" />

        <activity
            android:name=".LuckySpinActivity"
            android:exported="false"
            android:theme="@style/Theme.RBXApp" />

        <activity
            android:name=".ScratchCardActivity"
            android:exported="false"
            android:theme="@style/Theme.RBXApp" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.RBXApp">
        </activity>
    </application>

</manifest>

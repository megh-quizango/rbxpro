<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottomAd"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:layout_gravity="bottom"
    android:layout_margin="16dp"
    android:background="@drawable/bg_bottom_ad_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <ImageView
        android:id="@+id/bottomAdIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ad_ic1" />

    <TextView
        android:id="@+id/bottomAdTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:text="Comprehensive Robx Guide"
        android:textColor="#000"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/bottomAdBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_install_button"
        android:text="Install"
        android:textAllCaps="false"
        android:textColor="#FFFFFF" />

</LinearLayout>
